mainmenu "EMS (Embedded Middleware System) Configuration"

config EMS_VERSION
	string
	default "1.0.0"

# ============================================================================
# Build Configuration
# ============================================================================

menu "Build Options"

config BUILD_TYPE_DEBUG
	bool "Debug build"
	default n
	help
	  Enable debug symbols (-g), disable optimizations (-O0), and enable
	  verbose logging. Equivalent to CMAKE_BUILD_TYPE=Debug.
	  
	  If unsure, say N for production builds.

choice
	prompt "Optimization level"
	default OPT_O2 if !BUILD_TYPE_DEBUG
	default OPT_O0 if BUILD_TYPE_DEBUG
	help
	  Select compiler optimization level.

config OPT_O0
	bool "No optimization (-O0)"
	help
	  Disable all optimizations. Best for debugging with GDB.

config OPT_O2
	bool "Optimize for speed (-O2)"
	help
	  Standard optimization level. Good balance of speed and size.

config OPT_O3
	bool "Aggressive optimization (-O3)"
	help
	  Maximum speed optimization. May increase binary size.

config OPT_OS
	bool "Optimize for size (-Os)"
	help
	  Optimize for minimal binary size. Good for embedded systems.

endchoice

config BUILD_TESTING
	bool "Build unit tests"
	default y
	help
	  Build the test suite (ems-test, osal-test, hal-test, etc.).
	  Requires test framework to be available.

config BUILD_SHARED_LIBS
	bool "Build shared libraries"
	default n
	help
	  Build .so shared libraries instead of .a static libraries.
	  
	  If unsure, say N for embedded systems.

config INSTALL_HEADERS
	bool "Install development headers"
	default y
	help
	  Install public header files for library development.

endmenu

# ============================================================================
# Architecture Selection
# ============================================================================

choice
	prompt "Target architecture"
	default ARCH_X86_64
	help
	  Select the target CPU architecture.

config ARCH_X86_64
	bool "x86_64 (64-bit Intel/AMD)"

config ARCH_ARM32
	bool "ARM32 (ARMv7-A)"

config ARCH_ARM64
	bool "ARM64 (ARMv8-A / AArch64)"

config ARCH_RISCV64
	bool "RISC-V 64-bit"

endchoice

config CROSS_COMPILE
	string "Cross-compiler prefix"
	default "" if ARCH_X86_64
	default "arm-linux-gnueabihf-" if ARCH_ARM32
	default "aarch64-linux-gnu-" if ARCH_ARM64
	default "riscv64-linux-gnu-" if ARCH_RISCV64
	help
	  Prefix for cross-compilation toolchain (e.g., "arm-linux-gnueabihf-").
	  Leave empty for native compilation.

# ============================================================================
# OSAL Configuration
# ============================================================================

menu "OSAL (Operating System Abstraction Layer)"
source "core/osal/Kconfig"
endmenu

# ============================================================================
# HAL Configuration
# ============================================================================

menu "HAL (Hardware Abstraction Layer)"
source "core/hal/Kconfig"
endmenu

# ============================================================================
# PCL Configuration
# ============================================================================

menu "PCL (Peripheral Configuration Library)"
source "core/pcl/Kconfig"
endmenu

# ============================================================================
# PDL Configuration
# ============================================================================

menu "PDL (Peripheral Driver Layer)"
source "core/pdl/Kconfig"
endmenu

# ============================================================================
# ACL Configuration
# ============================================================================

menu "ACL (Application Configuration Layer)"
source "core/acl/Kconfig"
endmenu

# ============================================================================
# Product Selection
# ============================================================================

choice
	prompt "Product line"
	default PRODUCT_PMC
	help
	  Select the target product line.

config PRODUCT_PMC
	bool "PMC (Power Management Controller)"
	help
	  Build for PMC product line (satellite power management).

config PRODUCT_SAMPLES
	bool "Sample applications"
	help
	  Build sample/demo applications only.

endchoice

menu "Product Configuration"
depends on PRODUCT_PMC || PRODUCT_SAMPLES

if PRODUCT_PMC
source "products/pmc/Kconfig"
endif

if PRODUCT_SAMPLES
source "products/samples/Kconfig"
endif

endmenu

# ============================================================================
# Test Configuration
# ============================================================================

menu "Test Configuration"
depends on BUILD_TESTING
source "tests/Kconfig"
endmenu
