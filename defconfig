#
# EMS Default Configuration
#

# Build Options
# CONFIG_BUILD_TYPE_DEBUG is not set
CONFIG_OPT_O2=y
CONFIG_BUILD_TESTING=y
# CONFIG_BUILD_SHARED_LIBS is not set
CONFIG_INSTALL_HEADERS=y

# Architecture
CONFIG_ARCH_X86_64=y
CONFIG_CROSS_COMPILE=""

# OSAL
CONFIG_OSAL_MAX_TASKS=64
CONFIG_OSAL_MAX_QUEUES=32
CONFIG_OSAL_MAX_MUTEXES=32

# HAL Drivers
CONFIG_HAL_CAN=y
CONFIG_HAL_CAN_DEVICE="can0"
CONFIG_HAL_UART=y
CONFIG_HAL_UART_DEVICE="/dev/ttyS0"
CONFIG_HAL_UART_BAUDRATE=115200
CONFIG_HAL_UART_DATABITS=8
CONFIG_HAL_UART_PARITY_NONE=y
CONFIG_HAL_UART_STOPBITS=1
# CONFIG_HAL_I2C is not set
# CONFIG_HAL_SPI is not set
CONFIG_HAL_GPIO=y
CONFIG_HAL_WATCHDOG=y
CONFIG_HAL_WATCHDOG_DEVICE="/dev/watchdog"
CONFIG_HAL_WATCHDOG_TIMEOUT=30

# PCL Platform
CONFIG_PCL_PLATFORM_TI_AM625=y
CONFIG_PCL_PRODUCT_H200_100P=y

# PDL
CONFIG_PDL_SATELLITE_SUPPORT=y
CONFIG_PDL_BMC_SUPPORT=y
CONFIG_PDL_MCU_SUPPORT=y

# ACL
CONFIG_ACL_MAX_DEVICES=64

# Product
CONFIG_PRODUCT_PMC=y
CONFIG_PROJECT_H200_AM625=y

# PMC Applications
CONFIG_BUILD_PMC_SUPERVISOR=y
CONFIG_BUILD_PMC_COLLECTOR=y
CONFIG_BUILD_PMC_COMM=y
CONFIG_BUILD_PMC_HEALTH=y
CONFIG_BUILD_PMC_LOGGER=y

# Tests
CONFIG_TEST_OSAL=y
CONFIG_TEST_HAL=y
CONFIG_TEST_PCL=y
CONFIG_TEST_PDL=y
CONFIG_TEST_ACL=y
