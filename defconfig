#
# EMS Default Configuration
#
CONFIG_EMS_VERSION="1.0.0"

#
# Build Options
#
# CONFIG_BUILD_TYPE_DEBUG is not set
CONFIG_OPT_O2=y
# CONFIG_OPT_O0 is not set
# CONFIG_OPT_O3 is not set
# CONFIG_OPT_OS is not set
CONFIG_BUILD_TESTING=y
# CONFIG_BUILD_SHARED_LIBS is not set
CONFIG_INSTALL_HEADERS=y

#
# Architecture Selection
#
CONFIG_ARCH_X86_64=y
# CONFIG_ARCH_ARM32 is not set
# CONFIG_ARCH_ARM64 is not set
# CONFIG_ARCH_RISCV64 is not set
CONFIG_CROSS_COMPILE=""

#
# OSAL Configuration
#
CONFIG_OSAL=y
CONFIG_OSAL_MAX_TASKS=64
CONFIG_OSAL_MAX_QUEUES=32
CONFIG_OSAL_MAX_MUTEXES=32
# CONFIG_OSAL_DEBUG_LOGGING is not set

#
# HAL Configuration
#
CONFIG_HAL=y
CONFIG_HAL_CAN=y
CONFIG_HAL_UART=y
# CONFIG_HAL_I2C is not set
# CONFIG_HAL_SPI is not set
CONFIG_HAL_GPIO=y
CONFIG_HAL_WATCHDOG=y

#
# PCL Configuration
#
CONFIG_PCL=y

#
# PDL Configuration
#
CONFIG_PDL=y

#
# ACL Configuration
#
CONFIG_ACL=y
CONFIG_ACL_MAX_DEVICES=64

#
# Product Selection
#
CONFIG_PRODUCT_CCM=y
# CONFIG_PRODUCT_SAMPLES is not set
