# =============================================================================
# 应用程序模板 - 复制此文件创建新应用
# =============================================================================
# 使用说明：
# 1. 复制此文件到你的应用目录
# 2. 将所有 "myapp" 替换为你的应用名（小写）
# 3. 将所有 "MYAPP" 替换为你的应用名（大写）
# 4. 修改源文件列表、头文件路径、依赖库
# 5. 在顶层 Makefile 中添加：include products/xxx/myapp/module.mk
# =============================================================================

# -----------------------------------------------------------------------------
# 第 1 步：定义源文件（必填）
# -----------------------------------------------------------------------------
# 列出所有 .c 源文件的完整路径
myapp_SRCS := \
	products/samples/myapp/src/main.c \
	products/samples/myapp/src/myapp.c

# -----------------------------------------------------------------------------
# 第 2 步：定义头文件路径（必填）
# -----------------------------------------------------------------------------
# 添加本模块的头文件目录
myapp_CFLAGS := \
	-Iproducts/samples/myapp/include

# 添加依赖模块的头文件（从 staging 目录）
myapp_CFLAGS += \
	 \
	

# -----------------------------------------------------------------------------
# 第 3 步：定义链接库（必填）
# -----------------------------------------------------------------------------
# 设置库搜索路径
myapp_LDFLAGS := -L$(STAGING_DIR)/lib

# 链接需要的库（按依赖顺序，从高到低）
myapp_LDFLAGS += \
	-Wl,--no-as-needed \
	-losal \
	-Wl,--as-needed

# 链接系统库（如果需要）
myapp_LDFLAGS += -lpthread

# -----------------------------------------------------------------------------
# 第 4 步：配置开关（可选）
# -----------------------------------------------------------------------------
# 根据 Kconfig 配置决定是否构建此应用
# 在 Kconfig 中添加：config BUILD_MYAPP
ifeq ($(CONFIG_BUILD_MYAPP),y)
  MYAPP_ENABLED := y
else
  MYAPP_ENABLED := n
endif

# -----------------------------------------------------------------------------
# 以下内容通常不需要修改（标准构建流程）
# -----------------------------------------------------------------------------

# 生成目标文件列表
myapp_OBJS := $(call srcs_to_objs,$(myapp_SRCS))

# 定义可执行文件路径
ifeq ($(MYAPP_ENABLED),y)
myapp_TARGET := $(STAGING_DIR)/bin/myapp
ALL_TARGETS += $(myapp_TARGET)
endif

# 添加编译标志
$(myapp_OBJS): CFLAGS += $(myapp_CFLAGS)

# 定义构建规则
ifeq ($(MYAPP_ENABLED),y)
# 声明依赖的库（确保库先构建）
$(myapp_TARGET): $(myapp_OBJS)
$(myapp_TARGET): $(STAGING_DIR)/lib/libosal.so

# 链接规则
$(myapp_TARGET):
	@echo "  LD      $@"
	@mkdir -p $(dir $@)
	@$(CC) -o $@ $(myapp_OBJS) $(myapp_LDFLAGS)
endif

# 清理规则
CLEAN_TARGETS += $(myapp_OBJS) $(myapp_TARGET)
