# ============================================================================
# CCM (Communication Controller Management) Product Configuration
# ============================================================================

menuconfig PRODUCT_CCM
	bool "CCM (Communication Controller Management)"
	default y
	help
	  Communication Controller Management product line.

	  CCM manages communication between external systems and device modules,
	  providing unified interfaces for CAN, Ethernet, UART communication.

	  If unsure, say Y.

if PRODUCT_CCM

choice
	prompt "CCM Project"
	default PROJECT_H200_AM625
	help
	  Select the CCM project variant (hardware platform).

config PROJECT_H200_AM625
	bool "H200 AM625"
	help
	  H200 project based on TI AM625 SoC.

	  Platform: TI AM625 (Cortex-A53 + Cortex-R5F)
	  Product: H200-100P / H200-200P

endchoice

menu "CCM Applications"

config BUILD_CCM_SUPERVISOR
	bool "CCM Supervisor"
	default y
	help
	  Build the CCM supervisor application.

	  The supervisor manages lifecycle of all CCM applications,
	  handles process monitoring and automatic restart.

config BUILD_CCM_COLLECTOR
	bool "CCM Collector"
	default y
	help
	  Build the CCM data collector application.

	  The collector gathers data from peripheral devices
	  (satellites, BMC, MCU) and forwards to external systems.

config BUILD_CCM_COMM
	bool "CCM Communication"
	default y
	help
	  Build the CCM communication application.

	  The communication module handles CAN/Ethernet/UART
	  protocol processing and message routing.

config BUILD_CCM_HEALTH
	bool "CCM Health Monitor"
	default y
	help
	  Build the CCM health monitoring application.

	  The health monitor tracks system status, peripheral
	  health, and generates alerts for failures.

config BUILD_CCM_LOGGER
	bool "CCM Logger"
	default y
	help
	  Build the CCM logging application.

	  The logger provides centralized logging service
	  for all CCM applications with log rotation.

endmenu

endif # PRODUCT_CCM
