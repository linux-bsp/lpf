# =============================================================================
# ccm_collector 应用构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 可执行程序目标
# -----------------------------------------------------------------------------
app-y += ccm_collector

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
ccm_collector-objs := \
	src/main.o \
	src/ccm_collector.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
ccflags-y += -I$(src)/include
# 注意：所有库头文件通过 staging 目录引用（顶层 Makefile 已全局导出 INCLUDE_DIR）
ccflags-y += -I$(INCLUDE_DIR)

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
ccm_collector-ldflags := -L$(LIB_DIR)
ccm_collector-ldflags += -Wl,-rpath,$$ORIGIN/../lib
ccm_collector-ldflags += -lh200_am625 -lccm
ccm_collector-ldflags += -lacl -lpdl -lpcl -lhal -losal

# -----------------------------------------------------------------------------
# 5. 清理规则
# -----------------------------------------------------------------------------
clean-files := ccm_collector
