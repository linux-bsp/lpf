# =============================================================================
# libccm 库构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 构建目标配置
# -----------------------------------------------------------------------------
# 静态库
lib-y += ccm

# 动态库
so-y += ccm

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
ccm-objs := \
	src/libccm_ipc.o \
	src/libccm_protocol.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
ccflags-y += -I$(src)/include
# 注意：OSAL/HAL 头文件通过 staging 目录引用（顶层 Makefile 已全局导出）
# 注意：Kconfig 生成的配置文件在 $(srctree)/include
ccflags-y += -I$(srctree)/include

# 动态库需要 -fPIC
ccm-cflags-y := -fPIC

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
# 动态库链接标志
ccm-ldflags := -shared -Wl$(comma)-soname$(comma)libccm.so.1
ccm-ldflags += -L$(LIB_DIR) -losal

# -----------------------------------------------------------------------------
# 5. 头文件导出
# -----------------------------------------------------------------------------
header-y := ccm_common.h ccm_utils.h libccm_ipc.h libccm_protocol.h

# -----------------------------------------------------------------------------
# 6. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
