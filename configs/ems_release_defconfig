#
# EMS Release Build Configuration
#

# Build Options
# CONFIG_BUILD_TYPE_DEBUG is not set
CONFIG_OPT_OS=y
# CONFIG_BUILD_TESTING is not set
CONFIG_BUILD_SHARED_LIBS=y
CONFIG_INSTALL_HEADERS=y

# Architecture
CONFIG_ARCH_ARM64=y
CONFIG_CROSS_COMPILE="aarch64-linux-gnu-"

# OSAL (minimal limits for production)
CONFIG_OSAL_MAX_TASKS=32
CONFIG_OSAL_MAX_QUEUES=16
CONFIG_OSAL_MAX_MUTEXES=16

# HAL (only required drivers)
CONFIG_HAL_CAN=y
CONFIG_HAL_CAN_DEVICE="can0"
CONFIG_HAL_UART=y
CONFIG_HAL_UART_DEVICE="/dev/ttyS0"
CONFIG_HAL_UART_BAUDRATE=115200
# CONFIG_HAL_I2C is not set
# CONFIG_HAL_SPI is not set
CONFIG_HAL_GPIO=y
CONFIG_HAL_WATCHDOG=y

# Product
CONFIG_PRODUCT_PMC=y
CONFIG_PROJECT_H200_AM625=y
CONFIG_BUILD_PMC_SUPERVISOR=y
CONFIG_BUILD_PMC_COLLECTOR=y
CONFIG_BUILD_PMC_COMM=y
CONFIG_BUILD_PMC_HEALTH=y
CONFIG_BUILD_PMC_LOGGER=y
