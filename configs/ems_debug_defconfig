#
# EMS Debug Build Configuration
#

# Build Options
CONFIG_BUILD_TYPE_DEBUG=y
CONFIG_OPT_O0=y
CONFIG_BUILD_TESTING=y
CONFIG_INSTALL_HEADERS=y

# Architecture
CONFIG_ARCH_X86_64=y

# OSAL (increased limits for debugging)
CONFIG_OSAL_MAX_TASKS=128
CONFIG_OSAL_MAX_QUEUES=64
CONFIG_OSAL_MAX_MUTEXES=64
CONFIG_OSAL_DEBUG_LOGGING=y

# HAL (all drivers enabled for testing)
CONFIG_HAL_CAN=y
CONFIG_HAL_CAN_DEVICE="vcan0"
CONFIG_HAL_UART=y
CONFIG_HAL_UART_DEVICE="/dev/ttyUSB0"
CONFIG_HAL_UART_BAUDRATE=115200
CONFIG_HAL_I2C=y
CONFIG_HAL_SPI=y
CONFIG_HAL_GPIO=y
CONFIG_HAL_WATCHDOG=y

# Product
CONFIG_PRODUCT_PMC=y
CONFIG_PROJECT_H200_AM625=y
CONFIG_BUILD_PMC_SUPERVISOR=y
CONFIG_BUILD_PMC_COLLECTOR=y
CONFIG_BUILD_PMC_COMM=y
CONFIG_BUILD_PMC_HEALTH=y
CONFIG_BUILD_PMC_LOGGER=y
