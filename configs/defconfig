#
# EMS Default Configuration
# Optimized for x86_64 platform with all features enabled
#

# ============================================================================
# Build Options
# ============================================================================
CONFIG_OPT_O2=y
CONFIG_LIBRARY_BUILD_TYPE_STATIC=y
CONFIG_LIBRARY_BUILD_TYPE_DYNAMIC=y
CONFIG_INSTALL_HEADERS=y

# ============================================================================
# Architecture
# ============================================================================
CONFIG_ARCH_X86_64=y
CONFIG_CROSS_COMPILE=""

# ============================================================================
# OSAL (Operating System Abstraction Layer)
# ============================================================================
CONFIG_OSAL=y
CONFIG_OSAL_BUILD_STATIC=y
CONFIG_OSAL_BUILD_SHARED=y

# OSAL Features (All enabled)
CONFIG_OSAL_FILE=y
CONFIG_OSAL_NETWORK=y
CONFIG_OSAL_IPC=y
CONFIG_OSAL_THREAD=y

# OSAL Resource Limits
CONFIG_OSAL_MAX_TASKS=128
CONFIG_OSAL_MAX_QUEUES=64
CONFIG_OSAL_MAX_MUTEXES=64
CONFIG_OSAL_MAX_SEMAPHORES=64
CONFIG_OSAL_MAX_TIMERS=32

# ============================================================================
# HAL (Hardware Abstraction Layer)
# ============================================================================
CONFIG_HAL=y
CONFIG_HAL_BUILD_STATIC=y
CONFIG_HAL_BUILD_SHARED=y

# HAL Drivers (All enabled)
CONFIG_HAL_CAN=y
CONFIG_HAL_CAN_DEVICE="can0"
CONFIG_HAL_CAN_BITRATE=500000

CONFIG_HAL_UART=y
CONFIG_HAL_UART_DEVICE="/dev/ttyS0"
CONFIG_HAL_UART_BAUDRATE=115200

CONFIG_HAL_I2C=y
CONFIG_HAL_I2C_DEVICE="/dev/i2c-0"

CONFIG_HAL_SPI=y
CONFIG_HAL_SPI_DEVICE="/dev/spidev0.0"

CONFIG_HAL_GPIO=y
CONFIG_HAL_GPIO_BASE=0

CONFIG_HAL_WATCHDOG=y
CONFIG_HAL_WATCHDOG_DEVICE="/dev/watchdog"
CONFIG_HAL_WATCHDOG_TIMEOUT=30

# ============================================================================
# PCL (Protocol Control Layer)
# ============================================================================
CONFIG_PCL=y
CONFIG_PCL_BUILD_STATIC=y
CONFIG_PCL_BUILD_SHARED=y

# ============================================================================
# PDL (Protocol Data Layer)
# ============================================================================
CONFIG_PDL=y
CONFIG_PDL_BUILD_STATIC=y
CONFIG_PDL_BUILD_SHARED=y

# PDL Modules (All enabled)
CONFIG_PDL_MCU_ENABLE=y
CONFIG_PDL_MCU_PROTOCOL_VERSION=2
CONFIG_PDL_MCU_MAX_DEVICES=16

CONFIG_PDL_SATELLITE_ENABLE=y
CONFIG_PDL_SATELLITE_MAX_DEVICES=32

CONFIG_PDL_BMC_ENABLE=y
CONFIG_PDL_BMC_REDFISH_SUPPORT=y
CONFIG_PDL_BMC_IPMI_SUPPORT=y
CONFIG_PDL_BMC_MAX_SESSIONS=8

CONFIG_PDL_WATCHDOG_SUPPORT=y

# ============================================================================
# ACL (Application Control Layer)
# ============================================================================
CONFIG_ACL=y
CONFIG_ACL_BUILD_STATIC=y
CONFIG_ACL_BUILD_SHARED=y

# ACL Features
CONFIG_ACL_TELEMETRY_CACHE=y
CONFIG_ACL_CACHE_SIZE=512
CONFIG_ACL_CACHE_TIMEOUT=60

# ============================================================================
# Products
# ============================================================================
CONFIG_PRODUCT_CCM=y
CONFIG_PROJECT_H200_AM625=y

# CCM Libraries
CONFIG_BUILD_LIBCCM=y
CONFIG_LIBCCM_BUILD_STATIC=y
CONFIG_LIBCCM_BUILD_SHARED=y

# CCM Applications (All enabled)
CONFIG_BUILD_CCM_SUPERVISOR=y
CONFIG_CCM_SUPERVISOR_PORT=8001
CONFIG_CCM_SUPERVISOR_LOG_LEVEL=2

CONFIG_BUILD_CCM_COLLECTOR=y
CONFIG_CCM_COLLECTOR_INTERVAL=1000
CONFIG_CCM_COLLECTOR_BUFFER_SIZE=4096

CONFIG_BUILD_CCM_COMM=y
CONFIG_CCM_COMM_PORT=8002
CONFIG_CCM_COMM_MAX_CLIENTS=32

CONFIG_BUILD_CCM_HEALTH=y
CONFIG_CCM_HEALTH_CHECK_INTERVAL=5000
CONFIG_CCM_HEALTH_THRESHOLD=80

CONFIG_BUILD_CCM_LOGGER=y
CONFIG_CCM_LOGGER_MAX_SIZE=10485760
CONFIG_CCM_LOGGER_ROTATE_COUNT=5

# ============================================================================
# Debugging Options
# ============================================================================
CONFIG_LOG_LEVEL=2
