{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "x86_64-full",
      "displayName": "x86_64 Full (Development)",
      "description": "Development build with all features enabled, -O2 optimization",
      "binaryDir": "${sourceDir}/build-x86_64-full",
      "cacheVariables": {
        "DEFCONFIG": "x86_64_full",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "x86_64-minimal",
      "displayName": "x86_64 Minimal (Production)",
      "description": "Production build with minimal features, -Os optimization",
      "binaryDir": "${sourceDir}/build-x86_64-minimal",
      "cacheVariables": {
        "DEFCONFIG": "x86_64_minimal",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x86_64-test",
      "displayName": "x86_64 Test (CI/CD)",
      "description": "Test build with all features and testing enabled",
      "binaryDir": "${sourceDir}/build-x86_64-test",
      "cacheVariables": {
        "DEFCONFIG": "x86_64_test",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x86_64-debug",
      "displayName": "x86_64 Debug",
      "description": "Debug build with -O0 -g3, all features enabled",
      "binaryDir": "${sourceDir}/build-x86_64-debug",
      "cacheVariables": {
        "DEFCONFIG": "x86_64_full",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "arm64-full",
      "displayName": "ARM64 Full (Development)",
      "description": "ARM64 development build with all features",
      "binaryDir": "${sourceDir}/build-arm64-full",
      "cacheVariables": {
        "DEFCONFIG": "arm64_full",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "arm64-minimal",
      "displayName": "ARM64 Minimal (Production)",
      "description": "ARM64 production build with minimal features",
      "binaryDir": "${sourceDir}/build-arm64-minimal",
      "cacheVariables": {
        "DEFCONFIG": "arm64_minimal",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x86_64-full",
      "configurePreset": "x86_64-full",
      "displayName": "Build x86_64 Full",
      "description": "Build with parallel jobs",
      "jobs": 0
    },
    {
      "name": "x86_64-minimal",
      "configurePreset": "x86_64-minimal",
      "displayName": "Build x86_64 Minimal",
      "jobs": 0
    },
    {
      "name": "x86_64-test",
      "configurePreset": "x86_64-test",
      "displayName": "Build x86_64 Test",
      "jobs": 0
    },
    {
      "name": "x86_64-debug",
      "configurePreset": "x86_64-debug",
      "displayName": "Build x86_64 Debug",
      "jobs": 0
    },
    {
      "name": "arm64-full",
      "configurePreset": "arm64-full",
      "displayName": "Build ARM64 Full",
      "jobs": 0
    },
    {
      "name": "arm64-minimal",
      "configurePreset": "arm64-minimal",
      "displayName": "Build ARM64 Minimal",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "x86_64-test",
      "configurePreset": "x86_64-test",
      "displayName": "Test x86_64",
      "description": "Run all tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
