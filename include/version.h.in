/* Auto-generated version information */
#ifndef __EMS_VERSION_H__
#define __EMS_VERSION_H__

#define EMS_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define EMS_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define EMS_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define EMS_VERSION_STRING "@PROJECT_VERSION@"

#define EMS_GIT_HASH "@GIT_HASH@"
#define EMS_GIT_BRANCH "@GIT_BRANCH@"
#define EMS_GIT_DIRTY "@GIT_DIRTY@"

#define EMS_BUILD_DATE "@BUILD_DATE@"
#define EMS_BUILD_TIME "@BUILD_TIME@"
#define EMS_BUILD_TIMESTAMP "@BUILD_TIMESTAMP@"

#define EMS_BUILD_TYPE "@CMAKE_BUILD_TYPE@"
#define EMS_COMPILER "@CMAKE_C_COMPILER_ID@ @CMAKE_C_COMPILER_VERSION@"
#define EMS_SYSTEM "@CMAKE_SYSTEM_NAME@ @CMAKE_SYSTEM_PROCESSOR@"

#define EMS_DEFCONFIG "@DEFCONFIG_NAME@"

/* Full version string with git info */
#define EMS_FULL_VERSION EMS_VERSION_STRING "-" EMS_GIT_HASH EMS_GIT_DIRTY

#endif /* __EMS_VERSION_H__ */
