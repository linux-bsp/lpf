# PDM Configuration Module Configuration

config PDM_CONFIGS
	tristate "PDM configuration engine and data providers"
	default m
	depends on OSAL
	depends on m
	help
	  Build pdm_configs.ko. This module owns PDM configuration loading,
	  backend selection, validation, normalization, and the unified
	  configured-device node table consumed by pdm_core.ko.

	  Static platform configuration tables and Device Tree parsing are both
	  implemented inside this module.

if PDM_CONFIGS

config PDM_CONFIG_SOURCE_STATIC
	bool "Enable static platform config provider"
	default y
	help
	  Enable the compiled static platform configuration provider.

config PDM_CONFIG_SOURCE_DT
	bool "Enable Device Tree config provider"
	default y if OF
	depends on OF
	help
	  Enable the Device Tree configuration provider.

menu "PDM Static Platform Config Selection"

depends on PDM_CONFIG_SOURCE_STATIC

choice
	prompt "Selected PDM static config"
	default PDM_CONFIG_UBUNTU_X86_MOCK_MODULES if PDM_SOC_ADAPTER_MOCK
	default PDM_CONFIG_IMX6ULL_MODULES if ARCH_ARM32
	default PDM_CONFIG_UBUNTU_X86_MODULES
	help
	  Select the single static platform configuration compiled into
	  pdm_configs.ko.

config PDM_CONFIG_IMX6ULL_MODULES
	bool "imx6ull/modules v1"

config PDM_CONFIG_UBUNTU_X86_MODULES
	bool "ubuntu/x86_modules v1"

config PDM_CONFIG_UBUNTU_X86_MOCK_MODULES
	bool "ubuntu/x86_mock_modules v1"

endchoice

endmenu

config PDM_CONFIG_OF_SELFTEST
	bool "Build PDM Device Tree config self-test"
	default n
	depends on PDM_CONFIG_SOURCE_DT
	depends on PDM_SOC_ADAPTER_MOCK
	help
	  Build the PDM Device Tree configuration self-test into
	  pdm_configs.ko. This validates the PDM Device Tree parser through
	  Linux OF accessors on kernels with CONFIG_OF enabled.

endif # PDM_CONFIGS
