# PDM MCU service configuration

if PDM_MCU_SERVICE

config PDM_MCU_MAX_DEVICES
	int "Maximum number of MCU devices"
	default 4
	range 1 16
	help
	  Maximum number of MCU devices that can be managed simultaneously.
	  Each device requires approximately 200 bytes of RAM.

config PDM_MCU_TRANSPORT_CAN
	bool "PDM MCU CAN transport"
	default y
	depends on PDM_HW_CAN
	help
	  Enable the CAN-backed transport implementation used by the PDM MCU
	  service for PDM_CONFIG_MCU_INTERFACE_CAN entries.

config PDM_MCU_TRANSPORT_UART
	bool "PDM MCU UART transport"
	default y
	depends on PDM_HW_UART
	help
	  Enable the UART-backed transport implementation used by the PDM MCU
	  service for PDM_CONFIG_MCU_INTERFACE_SERIAL entries.

endif # PDM_MCU_SERVICE
