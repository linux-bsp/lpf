# PDM HW configuration

menu "Platform Configuration"

config PLATFORM_LINUX
	bool "Linux platform"
	default n
	depends on OS_LINUX
	help
	  Enable Linux hardware access support.

	  Uses Linux kernel interfaces:
	  - SocketCAN kernel sockets for CAN bus
	  - TTY, GPIO, I2C, and SPI kernel subsystems

	  Suitable for Linux systems with standard kernel drivers.

endmenu

menu "PDM HW Configuration"

config PDM_HW_CAN
	bool "PDM HW CAN transport support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW CAN transport path used by peripheral services.

config PDM_HW_UART
	bool "PDM HW UART transport support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW UART transport path used by peripheral services.

config PDM_HW_I2C
	bool "PDM HW I2C bus support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW I2C bus path used by peripheral services.

config PDM_HW_SPI
	bool "PDM HW SPI bus support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW SPI bus path used by peripheral services.

config PDM_HW_GPIO
	bool "PDM HW GPIO control support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW GPIO control path used by peripheral services.

config PDM_HW_PWM
	bool "PDM HW PWM control support"
	default n
	depends on PDM_RUNTIME
	help
	  Enable the PDM HW PWM control path used by peripheral services.

config PDM_HW_MOCK_SELFTEST
	tristate "Build PDM HW mock backend self-test module"
	depends on PDM_SOC_ADAPTER_MOCK && PDM_RUNTIME
	depends on m
	select PDM_HW_CAN
	select PDM_HW_UART
	select PDM_HW_I2C
	select PDM_HW_SPI
	select PDM_HW_GPIO
	select PDM_HW_PWM
	help
	  Build pdm_hw_mock_selftest.ko. Loading this module runs PDM HW
	  GPIO, PWM, CAN, UART, I2C, and SPI operation checks through the
	  mock SoC adapter.

endmenu
