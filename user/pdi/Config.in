# PDI (Peripheral Driver Interface) Configuration

menuconfig PDI
	bool "PDI (Peripheral Driver Interface)"
	default n
	help
	  Userspace API library for PDM kernel peripheral devices.

	  PDI owns the userspace API surface, including device discovery
	  through the PDM control node /dev/pdm_manager and peripheral APIs such
	  as /dev/pdm/mcuN and /dev/pdm/ledN.

if PDI


menu "PDI logging"

config PDI_LOGGING_ENABLE
	bool "Enable PDI userspace logging"
	default y
	help
	  Enable the lightweight LOG_* interface owned by PDI.

if PDI_LOGGING_ENABLE

choice
	prompt "PDI userspace log level"
	default PDI_LOG_LEVEL_INFO if BUILD_TYPE_DEBUG
	default PDI_LOG_LEVEL_WARN if BUILD_TYPE_RELEASE
	default PDI_LOG_LEVEL_INFO
	help
	  Select the minimum PDI log priority compiled into userspace PDI.

config PDI_LOG_LEVEL_FATAL
	bool "FATAL - fatal errors only"

config PDI_LOG_LEVEL_ERROR
	bool "ERROR - errors and above"

config PDI_LOG_LEVEL_WARN
	bool "WARN - warnings and above"

config PDI_LOG_LEVEL_INFO
	bool "INFO - informational and above"

config PDI_LOG_LEVEL_DEBUG
	bool "DEBUG - debug and above"

endchoice

endif # PDI_LOGGING_ENABLE

endmenu

config PDI_BUILD_STATIC
	bool "Build static library (.a)"
	default y

config PDI_BUILD_SHARED
	bool "Build shared library (.so)"
	default n

endif # PDI
