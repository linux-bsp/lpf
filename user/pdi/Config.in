# PDI (Peripheral Driver Interface) Configuration

menuconfig PDI
	bool "PDI (Peripheral Driver Interface)"
	default n
	help
	  Userspace API library for PDM kernel peripheral devices.

	  PDI owns the userspace API surface, including device discovery
	  through the PDM control node /dev/pdm_manager and peripheral APIs such
	  as /dev/pdm/mcuN and /dev/pdm/ledN.

if PDI

config PDI_BUILD_STATIC
	bool "Build static library (.a)"
	default y

config PDI_BUILD_SHARED
	bool "Build shared library (.so)"
	default n

endif # PDI
